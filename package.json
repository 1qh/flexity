{
  "name": "ogrid-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "lib/*"
  ],
  "scripts": {
    "build": "turbo build",
    "check": "lintmax check",
    "clean": "rm -rf node_modules bun.lock .cache .turbo packages/*/node_modules apps/*/node_modules lib/*/node_modules packages/*/dist apps/*/dist apps/*/.next",
    "dev": "turbo dev",
    "fix": "lintmax fix && turbo build",
    "test": "turbo test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "lintmax": "latest",
    "turbo": "latest",
    "typescript": "latest"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "lintmax"
  ]
}
